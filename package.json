{
  "name": "powerbasefit-homepage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "quality:gate": "node scripts/quality-gate.mjs",
    "seo:submit": "node scripts/submit-search-engines.mjs",
    "seo:pt:check": "node scripts/check-pt-seo.mjs",
    "seo:daily": "node seo-engine/scripts/run-seo-engine.mjs --mode daily",
    "seo:weekly": "node seo-engine/scripts/run-seo-engine.mjs --mode weekly",
    "seo:monthly": "node seo-engine/scripts/run-seo-engine.mjs --mode monthly",
    "seo:draft": "node seo-engine/scripts/run-seo-engine.mjs --mode draft",
    "seo:commit": "node seo-engine/scripts/run-seo-engine.mjs --mode commit",
    "seo:publish": "node seo-engine/scripts/run-seo-engine.mjs --mode publish"
  },
  "browserslist": [
    "Chrome >= 111",
    "Edge >= 111",
    "Firefox >= 110",
    "Safari >= 16"
  ],
  "dependencies": {
    "@next/third-parties": "^16.2.10",
    "lucide-react": "^0.468.0",
    "next": "^15.5.7",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "lighthouse": "^13.4.0",
    "playwright-core": "^1.61.1",
    "typescript": "^5.7.2"
  }
}
